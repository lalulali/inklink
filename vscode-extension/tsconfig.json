{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "webview"]
}
